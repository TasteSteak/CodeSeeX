{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeSeeX Next",
  "version": "0.1.0",
  "identifier": "io.github.tastesteak.codeseex-next",
  "build": {
    "beforeDevCommand": "npm --prefix ../codeseex-ui run dev",
    "beforeBuildCommand": "npm --prefix ../codeseex-ui run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../codeseex-ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "CodeSeeX Next",
        "width": 1280,
        "height": 720,
        "minWidth": 1280,
        "minHeight": 720,
        "resizable": true,
        "decorations": false,
        "center": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
